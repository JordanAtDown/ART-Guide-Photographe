let history = [], currentNode = TREE;

function renderBreadcrumb() {
  const bc = document.getElementById('breadcrumb');
  if (!history.length) { bc.innerHTML = ''; return; }
  let h = `<span class="pb-crumb" onclick="pbGoHome()">Accueil</span>`;
  history.forEach((item, i) => {
    h += `<span class="pb-crumb-sep">›</span>`;
    if (i < history.length - 1)
      h += `<span class="pb-crumb" onclick="pbGoBreadcrumb(${i})">${item.label}</span>`;
    else
      h += `<span class="pb-crumb pb-crumb-active">${item.label}</span>`;
  });
  bc.innerHTML = h;
}

function renderStep(node) {
  const el = document.getElementById('pb-content');
  let h = `<div class="pb-step"><div class="pb-question">${node.question}</div><div class="pb-choices">`;
  node.choices.forEach(c => {
    h += `<button class="pb-choice" onclick="pbChoose('${c.id}')">
      <div class="pb-choice-icon">${svg(c.icon)}</div>
      <div class="pb-choice-text">
        <span class="pb-choice-name">${c.name}</span>
        <span class="pb-choice-sub">${c.sub}</span>
      </div>
    </button>`;
  });
  h += `</div>`;
  if (history.length) h += `<button class="pb-back" onclick="pbGoBack()">← Retour</button>`;
  h += `</div>`;
  el.innerHTML = h;
}

function renderResult(r) {
  const el = document.getElementById('pb-content');
  let h = `<div class="pb-result">`;
  h += `<div class="pb-restart-row">
      <button class="pb-restart" onclick="pbGoBack()">← Retour</button>
      <button class="pb-restart" onclick="pbGoHome()">↺ Recommencer</button>
    </div>`;
  h += `<div class="pb-result-banner">
    <div class="pb-result-banner-icon">${svg(r.icon)}</div>
    <div>
      <div class="pb-result-banner-title">${r.title}</div>
      <div class="pb-result-banner-sub">${r.sub}</div>
    </div>
  </div>`;
  h += `<div class="pb-section-label">Réglages Sony α7 II</div><div class="pb-settings-grid">`;
  r.settings.forEach(s => {
    h += `<div class="pb-setting">
      <span class="pb-setting-key">${s.k}</span>
      <span class="pb-setting-val ${s.c || ''}">${s.v}</span>
    </div>`;
  });
  h += `</div>`;
  if (r.filters && r.filters.length) {
    h += `<div class="pb-section-label">Filtres</div><div class="pb-filters">`;
    r.filters.forEach(f => {
      const lbl = f.s === 'yes' ? '✓ ' + f.t : f.s === 'opt' ? '○ ' + f.t : '✕ ' + f.t;
      h += `<span class="pb-filter-tag ${f.s}">${lbl}</span>`;
    });
    h += `</div>`;
  }
  h += `<div class="pb-section-label" style="margin-top:1.25rem">À retenir sur le terrain</div>
        <div class="pb-tips">`;
  r.tips.forEach(t => { h += `<div class="pb-tip">${t}</div>`; });
  h += `</div>
  </div>`;
  el.innerHTML = h;
}

window.pbChoose = function(id) {
  const choices = currentNode.choices || [];
  const choice = choices.find(c => c.id === id);
  if (!choice) return;
  history.push({label: choice.name, nodeRef: currentNode});
  if (choice.result) { renderBreadcrumb(); renderResult(choice.result); return; }
  if (choice.node) { currentNode = choice.node; renderBreadcrumb(); renderStep(currentNode); }
};

window.pbGoBack = function() {
  if (!history.length) return;
  const prev = history.pop();
  currentNode = prev.nodeRef;
  renderBreadcrumb(); renderStep(currentNode);
};

window.pbGoHome = function() {
  history = []; currentNode = TREE;
  renderBreadcrumb(); renderStep(currentNode);
};

window.pbGoBreadcrumb = function(idx) {
  const prev = history[idx];
  history = history.slice(0, idx);
  currentNode = prev.nodeRef;
  renderBreadcrumb(); renderStep(currentNode);
};

renderStep(currentNode);
})();
</script>


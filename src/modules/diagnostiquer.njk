<script>
const diagResults = {
  dr1a:{tag:'diag-tag-expo',label:'Exposition',title:'Hautes lumières cramées',desc:"L'information est perdue au-delà d'un certain seuil. En RAW, 1 à 2 IL sont récupérables selon le capteur.",modules:[{n:'Égaliseur Tonal — Hautes lumières',u:'egaliseurtonal',p:true},{n:'Log Tone Mapping',u:'logtonemapping',p:false},{n:'Compression Plage Dyn.',u:'compressiondyn',p:false}]},
  dr1b:{tag:'diag-tag-expo',label:'Exposition',title:'Ombres bouchées',desc:"Remonte les ombres dans l'Égaliseur Tonal. Attention : déboucher révèle du bruit numérique — active le Lissage NR ensuite.",modules:[{n:'Égaliseur Tonal — Ombres / Noirs',u:'egaliseurtonal',p:true},{n:'Lissage NR (bruit révélé)',u:'lissage',p:false}]},
  dr1c:{tag:'diag-tag-expo',label:'Exposition',title:'Image sous-exposée globalement',desc:"Commence par l'Exposition globale, puis sculpte avec l'Égaliseur Tonal pour éviter d'écrêter les hautes lumières.",modules:[{n:'Exposition',u:'exposition',p:true},{n:'Égaliseur Tonal — Ombres / HLs',u:'egaliseurtonal',p:false}]},
  dr1d:{tag:'diag-tag-expo',label:'Exposition',title:'Image surexposée globalement',desc:"Baisse l'Exposition, puis récupère les hautes lumières et les blancs séparément.",modules:[{n:'Exposition',u:'exposition',p:true},{n:'Égaliseur Tonal — HLs / Blancs',u:'egaliseurtonal',p:false}]},
  dr1e:{tag:'diag-tag-expo',label:'Exposition',title:'Plage dynamique trop large',desc:"Cas d'usage central du Log Tone Mapping. Clique Automatique, puis affine Blanc EV et Noir EV.",modules:[{n:'Log Tone Mapping',u:'logtonemapping',p:true},{n:'Égaliseur Tonal (affinage)',u:'egaliseurtonal',p:false}]},
  dr2a:{tag:'diag-tag-couleur',label:'Couleur',title:'Dominante froide / bleue',desc:"La Balance des Blancs est le premier réglage. Si la dominante est cyan, joue aussi sur le curseur Teinte.",modules:[{n:'Balance des Blancs — Température ↑',u:'balanceblancs',p:true},{n:'HSL — Bleu (saturation)',u:'eqcouleurs',p:false}]},
  dr2b:{tag:'diag-tag-couleur',label:'Couleur',title:'Dominante chaude / orange',desc:"Baisse la Température. En portrait, méfie-toi de trop refroidir — les tons chair ont besoin de chaleur.",modules:[{n:'Balance des Blancs — Température ↓',u:'balanceblancs',p:true},{n:'HSL — Orange (saturation)',u:'eqcouleurs',p:false}]},
  dr2c:{tag:'diag-tag-couleur',label:'Couleur',title:'Dominante verte',desc:"C'est le curseur Teinte (pas la Température) qui corrige les dominantes vertes des néons. Erreur fréquente.",modules:[{n:'Balance des Blancs — Teinte vers Magenta',u:'balanceblancs',p:true},{n:'HSL — Vert (saturation)',u:'eqcouleurs',p:false}]},
  dr2d:{tag:'diag-tag-couleur',label:'Couleur',title:'Dominante magenta / rosée',desc:"Inverse du vert. Décale la Teinte vers le vert.",modules:[{n:'Balance des Blancs — Teinte vers Vert',u:'balanceblancs',p:true},{n:'HSL — Rouge (saturation légère)',u:'eqcouleurs',p:false}]},
  dr2e:{tag:'diag-tag-couleur',label:'Couleur',title:'Couleurs fausses canal par canal',desc:"L'HSL est l'outil chirurgical. Travaille Teinte, Saturation et Luminance pour chaque couleur séparément.",modules:[{n:'Égaliseur HSL — canal par canal',u:'eqcouleurs',p:true},{n:'Mélange des Canaux (cas avancés)',u:'melange',p:false}]},
  dr2f:{tag:'diag-tag-couleur',label:'Couleur',title:'Couleurs ternes / désaturées',desc:"Préfère la Vibrance à la Saturation globale — elle protège les tons chair et les couleurs déjà bien saturées.",modules:[{n:'Saturation / Vibrance',u:'saturation',p:true},{n:'HSL — canaux ciblés',u:'eqcouleurs',p:false},{n:'Correction Couleurs (Color Wheels)',u:'correctioncouleurs',p:false}]},
  dr2g:{tag:'diag-tag-couleur',label:'Couleur',title:'Couleurs criardes / trop saturées',desc:"Identifie le canal coupable dans l'HSL plutôt que de tout baisser globalement.",modules:[{n:'Saturation / Vibrance — baisse',u:'saturation',p:true},{n:'HSL — canal concerné',u:'eqcouleurs',p:false}]},
  dr3a:{tag:'diag-tag-contraste',label:'Contraste',title:'Image molle, manque de punch',desc:"La Courbe en S est plus propre que le curseur Contraste global qui bouche les ombres et crâme les HLs ensemble.",modules:[{n:'Courbes Tonales — S-curve légère',u:'courbestonales',p:true},{n:'Contraste Local (microcontraste)',u:'contrastelocal',p:false}]},
  dr3b:{tag:'diag-tag-contraste',label:'Contraste',title:'Trop contrastée',desc:"Relève les ombres dans l'Égaliseur Tonal et adoucis la courbe tonale pour ouvrir les zones sombres.",modules:[{n:'Égaliseur Tonal — Ombres / Noirs',u:'egaliseurtonal',p:true},{n:'Courbes Tonales — relève le point bas',u:'courbestonales',p:false}]},
  dr3c:{tag:'diag-tag-contraste',label:'Contraste',title:'Manque de texture / matière',desc:"Ces modules s'appliquent en dernier, après exposition et couleur. Dos modérés — 0.15 à 0.30 max.",modules:[{n:'Amplification Texture',u:'texture',p:true},{n:'Contraste Local',u:'contrastelocal',p:false}]},
  dr3d:{tag:'diag-tag-contraste',label:'Contraste',title:'Halos sur les contours',desc:"Sur-application du Contraste Local ou du Lissage. Baisse les valeurs et change de mode si nécessaire.",modules:[{n:'Contraste Local — baisse la valeur',u:'contrastelocal',p:true},{n:'Lissage — mode moins agressif',u:'lissage',p:false}]},
  dr4a:{tag:'diag-tag-detail',label:'Détail',title:'Grain / bruit excessif',desc:"Distingue bruit de chrominance (taches colorées — toujours à traiter) et bruit de luminance (grain — à doser selon intention).",modules:[{n:'Lissage NR — Chrominance (priorité)',u:'lissage',p:true},{n:'Lissage NR — Luminance (au goût)',u:'lissage',p:false}]},
  dr4b:{tag:'diag-tag-detail',label:'Détail',title:'Taches colorées dans les ombres',desc:"C'est du bruit de chrominance. Le paramètre Chrominance du Lissage NR est fait exactement pour ça.",modules:[{n:'Lissage NR — Chrominance',u:'lissage',p:true}]},
  dr4c:{tag:'diag-tag-detail',label:'Détail',title:'Image floue',desc:"Si c'est un flou de mise au point ou de bougé, ART ne peut pas le récupérer. Si c'est un RAW non accentué, Texture + Contraste Local aident partiellement.",modules:[{n:'Amplification Texture (si RAW non accentué)',u:'texture',p:true},{n:'Contraste Local',u:'contrastelocal',p:false}]},
  dr4d:{tag:'diag-tag-detail',label:'Détail',title:'Surfaces plastifiées',desc:"Lissage NR trop agressif. Baisse la valeur Luminance. En portrait, le lissage fin de peau se fait dans Affinity, pas dans ART.",modules:[{n:'Lissage NR — Luminance (baisse)',u:'lissage',p:true}]},
  dr5a:{tag:'diag-tag-autre',label:'Autre',title:'Vignette indésirable',desc:"Si optique : Correction objectif avec profil auto. Si appliquée manuellement : cherche un curseur vignettage actif dans les modules.",modules:[{n:'Correction objectif — profil auto',u:'',p:true}]},
  dr5b:{tag:'diag-tag-autre',label:'Autre',title:'Distorsion géométrique',desc:"La correction de profil d'objectif corrige barillet et coussinet automatiquement pour la plupart des objectifs courants.",modules:[{n:'Correction objectif — profil auto',u:'',p:true}]},
  dr5c:{tag:'diag-tag-autre',label:'Autre',title:'Aberration chromatique / franges',desc:"Le module Correction objectif a un paramètre dédié. Si les franges résistent, correction manuelle canal par canal.",modules:[{n:'Correction objectif — Aberration chromatique',u:'',p:true}]},
  dr5d:{tag:'diag-tag-autre',label:'Autre',title:'Brume atmosphérique',desc:"Commence doucement — l'élimination de la brume crée des halos si poussé trop fort. Max 0.30 en général.",modules:[{n:'Élimination de la Brume (0.15–0.30)',u:'eliminationbrume',p:true},{n:'Contraste Local (après)',u:'contrastelocal',p:false}]}
};

const diagCategoryMap = {dr1a:'ds1',dr1b:'ds1',dr1c:'ds1',dr1d:'ds1',dr1e:'ds1',dr2a:'ds2',dr2b:'ds2',dr2c:'ds2',dr2d:'ds2',dr2e:'ds2',dr2f:'ds2',dr2g:'ds2',dr3a:'ds3',dr3b:'ds3',dr3c:'ds3',dr3d:'ds3',dr4a:'ds4',dr4b:'ds4',dr4c:'ds4',dr4d:'ds4',dr5a:'ds5',dr5b:'ds5',dr5c:'ds5',dr5d:'ds5'};
const BASE = '/ART-Guide-Photographe/modules/';
let diagCurrent = null;

function diagGo(id) {
  document.querySelectorAll('.diag-step').forEach(function(s){ s.classList.remove('diag-active'); });
  document.getElementById('diag-result-box').classList.remove('diag-active');
  var t = document.getElementById(id);
  if (t) t.classList.add('diag-active');
}

function diagShow(rid) {
  diagCurrent = rid;
  var r = diagResults[rid];
  if (!r) return;
  document.querySelectorAll('.diag-step').forEach(function(s){ s.classList.remove('diag-active'); });
  var mods = r.modules.map(function(m) {
    var cls = 'diag-mod' + (m.p ? ' diag-primary' : '');
    if (m.u) {
      return '<a class="' + cls + '" href="' + BASE + m.u + '/">' + m.n + '</a>';
    }
    return '<span class="' + cls + '">' + m.n + '</span>';
  }).join('');
  document.getElementById('diag-result-content').innerHTML =
    '<span class="diag-result-tag ' + r.tag + '">' + r.label + '</span>' +
    '<h5>' + r.title + '</h5>' +
    '<p>' + r.desc + '</p>' +
    '<div class="diag-mods">' + mods + '</div>';
  document.getElementById('diag-result-box').classList.add('diag-active');
}

function diagBackToCategory() {
  if (diagCurrent && diagCategoryMap[diagCurrent]) {
    diagGo(diagCategoryMap[diagCurrent]);
  } else {
    diagGo('ds0');
  }
}
</script>

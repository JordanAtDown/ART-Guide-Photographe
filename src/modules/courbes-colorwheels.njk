<table>
  <tr><th>Look</th><th>Ombres</th><th>Tons Moyens</th><th>Hautes Lumières</th></tr>
  <tr><td><strong>Méditerranée Cinématique</strong></td><td>Cyan ~200° / 0.12</td><td>Teal ~185° / 0.06</td><td>Jaune ~55° / 0.08</td></tr>
